---
import { getTags, slugifyTag } from '../lib/utils';

const tags = getTags();
---
<section id="habilidades">
    <h2>Habilidades técnicas</h3>
    <div class="flex flex-wrap gap-2 pl-6">
        {tags.map((tag) => (
            <a
                href={`/tags/${slugifyTag(tag)}`}
                class="bg-[#eef3ff] py-[0.3rem] px-[0.6rem] text-[0.9rem] rounded-md hover:bg-[lightgreen] hover:no-underline"
                title={`Ver experiencias con ${tag}`}>
                {tag}
            </a>
        ))}
    </div>
</section>